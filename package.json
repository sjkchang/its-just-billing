{
	"name": "its-just-billing",
	"version": "0.1.0",
	"description": "Self-contained billing engine with Stripe integration, subscription management, entitlements, and lifecycle hooks",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"files": ["dist"],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./client": {
			"types": "./dist/client.d.ts",
			"import": "./dist/client.js",
			"require": "./dist/client.cjs"
		},
		"./repositories/drizzle": {
			"types": "./dist/repositories/drizzle/index.d.ts",
			"import": "./dist/repositories/drizzle/index.js",
			"require": "./dist/repositories/drizzle/index.cjs"
		},
		"./providers/stripe": {
			"types": "./dist/providers/stripe/index.d.ts",
			"import": "./dist/providers/stripe/index.js",
			"require": "./dist/providers/stripe/index.cjs"
		}
	},
	"scripts": {
		"build": "tsup",
		"prepublishOnly": "pnpm build",
		"test": "vitest run",
		"test:providers": "vitest run src/__tests__/providers",
		"test:e2e": "vitest run --config e2e/vitest.config.ts"
	},
	"dependencies": {
		"nanoid": "^5.1.6",
		"trouter": "^4.0.0",
		"zod": "^3.25.76"
	},
	"peerDependencies": {
		"drizzle-orm": "^0.41.0",
		"stripe": "^20.0.0"
	},
	"peerDependenciesMeta": {
		"drizzle-orm": {
			"optional": true
		},
		"stripe": {
			"optional": true
		}
	},
	"devDependencies": {
		"@testcontainers/postgresql": "^10.18.0",
		"drizzle-orm": "^0.41.0",
		"hono": "^4.7.0",
		"postgres": "^3.4.5",
		"stripe": "^20.3.1",
		"testcontainers": "^10.18.0",
		"tsup": "^8.4.0",
		"typescript": "^5.7.2",
		"vitest": "^2.1.9"
	}
}
