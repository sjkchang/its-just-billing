{
	"compilerOptions": {
		"strict": true,
		"target": "ES2022",
		"lib": ["ES2022", "DOM"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"skipLibCheck": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"outDir": "./dist",
		"declaration": true,
		"declarationMap": false
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}
